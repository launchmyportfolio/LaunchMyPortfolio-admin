# Frontend Environment Configuration
# Copy this file to .env.local for local development

# Development environment - usually localhost
VITE_API_BASE_URL=http://localhost:5000/api

# Production environment (Render)
# When deployed on Render, set this in Render's environment variables dashboard
# Example: https://launchportfolio-api.onrender.com/api
VITE_API_PRODUCTION_URL=https://your-render-backend-url.onrender.com/api
