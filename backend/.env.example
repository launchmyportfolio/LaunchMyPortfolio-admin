# ===== DATABASE CONFIGURATION =====
# Local Development: 
# MONGO_URI=mongodb://localhost:27017/launchportfolio_admin

# Production (MongoDB Atlas):
# 1. Create cluster at mongodb.com/atlas
# 2. Get connection string from Atlas dashboard
# 3. Replace username, password, cluster name
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/launchportfolio_admin?retryWrites=true&w=majority

# ===== SERVER CONFIGURATION =====
PORT=5000

# Development: development
# Production: production
NODE_ENV=production

# ===== CORS CONFIGURATION =====
# List all frontend URLs that can access this API
# No trailing commas!
# Development: http://localhost:3000,http://127.0.0.1:3000
# Production: https://your-frontend.onrender.com
CORS_ORIGIN=https://launchportfolio-admin.onrender.com,http://localhost:3000

# ===== JWT CONFIGURATION =====
# Use a long, random string for production
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_use_long_random_string
JWT_EXPIRE=7d

# ===== EMAIL CONFIGURATION (Optional) =====
# For automated notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@launchmyportfolio.com
